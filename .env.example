# Supabase Postgres connection strings.
# Use the pooled connection string for deployed web apps.
# Example shape:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true"
# Use the direct connection string for Prisma migrations.
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"

# Supabase Auth. Find these in Supabase Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-your-supabase-anon-key"

AMAP_WEB_SERVICE_KEY="replace-with-your-amap-web-service-key"
NEXT_PUBLIC_AMAP_JS_KEY="replace-with-your-amap-js-key"
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE="replace-with-your-amap-security-js-code"

# Protects POST /api/amap/communities/collect in production.
COMMUNITY_POI_COLLECTOR_SECRET="replace-with-a-random-secret"

# Image generation for generated floor plan images.
# For official OpenAI, IMAGE_GEN_BASE_URL can stay as https://api.openai.com/v1.
# For a third-party compatible gateway, set it to that gateway's /v1 base URL.
IMAGE_GEN_BASE_URL="https://api.openai.com/v1"
IMAGE_GEN_API_KEY="replace-with-your-image-api-key"
IMAGE_GEN_MODEL="gpt-image-2"
IMAGE_GEN_SIZE="1024x1024"
IMAGE_GEN_QUALITY="medium"
